{
    "name": "@triliumnext/desktop-deno",
    "version": "0.103.0",
    "exports": "./main.ts",
    "tasks": {
        "start": "deno desktop --allow-env --allow-read --allow-net --allow-write --allow-run=xdg-open,open,explorer main.ts",
        "dev": "deno desktop --hmr --allow-env --allow-read --allow-net --allow-write --allow-run=xdg-open,open,explorer main.ts",
        "smoke": "TRILIUM_SMOKE=1 deno desktop --allow-env --allow-read --allow-net --allow-write --allow-run=xdg-open,open,explorer main.ts",
        "package": "deno desktop --output TriliumNotes.AppImage --include ../standalone/dist --allow-env --allow-read --allow-net --allow-write --allow-run=xdg-open,open,explorer main.ts"
    },
    "imports": {
        "@std/encoding": "jsr:@std/encoding@^1.0.0",
        "@std/http": "jsr:@std/http@^1.0.0"
    },
    "compilerOptions": {
        "lib": ["deno.window", "deno.desktop"]
    }
}
